# Economic Intelligence Agent v2.0 — Environment Variables
# Copy this file to .env and fill in your API keys

# ────────────────────────────────────────────────────
# Required: Choose ONE LLM provider
# ────────────────────────────────────────────────────

# Option 1: OpenRouter (Recommended — access to multiple models, free tier)
OPENROUTER_KEY=your_openrouter_api_key_here

# Option 2: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Option 3: Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ────────────────────────────────────────────────────
# Optional: Data source API keys
# ────────────────────────────────────────────────────

# FRED (Federal Reserve Economic Data) — free, 120 req/min
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Finnhub — free tier (60 req/min)
# Get key: https://finnhub.io/register
FINNHUB_KEY=your_finnhub_key_here

# NewsAPI — free tier (100 req/day)
# Get key: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage — free tier (25 req/day)
# Get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ExchangeRate API
EXCHANGERATE_KEY=your_exchangerate_key_here

# ────────────────────────────────────────────────────
# Optional: Alert notification channels
# ────────────────────────────────────────────────────

# Webhook (Slack or Discord)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# ALERT_EMAIL_TO=recipient@example.com
